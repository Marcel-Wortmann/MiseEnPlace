POSTGRES_USER=rezepte
POSTGRES_PASSWORD=rezepte
POSTGRES_DB=rezepte
FRONTEND_PORT=8080
BACKEND_PORT=3000

# Production: kommaseparierte Liste der erlaubten Origins.
# Beispiel: https://rezepte.example.com,capacitor://localhost,http://localhost
# In Dev (NODE_ENV != production) wird alles erlaubt.
FRONTEND_ORIGIN=
NODE_ENV=development

# JWT-Secret: in Production ZWINGEND setzen (App startet sonst nicht).
# Mit `openssl rand -base64 48` generieren.
JWT_SECRET=

# AI / Ollama
# Default für Linux: host.docker.internal wird via extra_hosts gemappt.
# Falls Ollama woanders läuft, hier anpassen, z.B. http://192.168.1.10:11434
# Wenn ein OpenWebUI-Gateway davor steht, hier den Passthrough-Pfad nutzen:
#   OLLAMA_BASE_URL=https://openwebui.example.com/ollama
# und unten OLLAMA_API_KEY auf den OpenWebUI-Bearer-Token setzen.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=
OLLAMA_VISION_MODEL=ministral-3:14b
OLLAMA_TEXT_MODEL=ministral-3:14b
TAVILY_API_KEY=

# BLS-Daten Auto-Download
# Falls die offizielle URL einen Token braucht (Anti-Hotlink), hier die volle URL inkl. ?token=… einsetzen.
# Default: https://blsdb.de/assets/uploads/BLS_4_0_2025_DE.zip
BLS_DOWNLOAD_URL=
